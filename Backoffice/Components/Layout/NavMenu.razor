@inject NavigationManager NavigationManager
@rendermode InteractiveServer
@implements IDisposable

<RadzenPanelMenu>
    <RadzenPanelMenuItem Text="Dashboard" Icon="dashboard" Path="" Match="NavLinkMatch.All" />
    <RadzenPanelMenuItem Text="Images" Icon="image" Path="images" Expanded="@IsActive("images")">
        <ChildContent>
            <RadzenPanelMenuItem Text="Upload" Icon="upload" Path="images/upload" />
            <RadzenPanelMenuItem Text="Edit" Icon="edit" Path="images" Match="NavLinkMatch.All" />
        </ChildContent>
    </RadzenPanelMenuItem>
    <RadzenPanelMenuItem Text="Hexagons" Icon="hexagon" Path="hexagons" Expanded="@IsActive("hexagons")">
        <ChildContent>
            <RadzenPanelMenuItem Text="Create" Icon="add" Path="hexagons/create" />
            <RadzenPanelMenuItem Text="Edit" Icon="edit" Path="hexagons" Match="NavLinkMatch.All" />
        </ChildContent>
    </RadzenPanelMenuItem>
    <RadzenPanelMenuItem Text="Turbulences" Icon="speed" Path="turbulences" Expanded="@IsActive("turbulences")">
        <ChildContent>
            <RadzenPanelMenuItem Text="Create" Icon="add" Path="turbulences/create" />
            <RadzenPanelMenuItem Text="Edit" Icon="edit" Path="turbulences" Match="NavLinkMatch.All" />
        </ChildContent>
    </RadzenPanelMenuItem>
    <RadzenPanelMenuItem Text="Anomalies" Icon="warning" Path="anomalies" Expanded="@IsActive("anomalies")">
        <ChildContent>
            <RadzenPanelMenuItem Text="Create" Icon="add" Path="anomalies/create" />
            <RadzenPanelMenuItem Text="Edit" Icon="edit" Path="anomalies" Match="NavLinkMatch.All" />
        </ChildContent>
    </RadzenPanelMenuItem>
</RadzenPanelMenu>

@code {
    protected override void OnInitialized()
    {
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
        => StateHasChanged();

    private bool IsActive(string section) =>
        NavigationManager.Uri.Contains($"/{section}", StringComparison.OrdinalIgnoreCase);

    public void Dispose() => NavigationManager.LocationChanged -= OnLocationChanged;
}
