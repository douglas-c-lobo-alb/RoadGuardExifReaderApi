@page "/hexagons/{Id:int}/edit"
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService
@rendermode InteractiveServer

<PageTitle>Edit Hexagon</PageTitle>

<h1>Edit Hexagon</h1>

@if (!loaded)
{
    <p>Loading...</p>
}
else
{
    <div style="max-width:500px">
        <div class="mb-3">
            <label class="form-label fw-semibold">Image</label>
            <RadzenDropDown TValue="int" @bind-Value="imageId" Data="@images"
                            TextProperty="FileName" ValueProperty="Id"
                            Placeholder="— select an image —" Style="width:100%" />
        </div>

        <div class="mb-3">
            <label class="form-label fw-semibold">Input method</label>
            <RadzenRadioButtonList TValue="InputMode" @bind-Value="mode" Orientation="Orientation.Horizontal">
                <Items>
                    <RadzenRadioButtonListItem Text="By Coordinates" Value="InputMode.Coordinates" />
                    <RadzenRadioButtonListItem Text="By H3 Index" Value="InputMode.H3Index" />
                </Items>
            </RadzenRadioButtonList>
        </div>

        @if (mode == InputMode.Coordinates)
        {
            <div class="mb-3">
                <label class="form-label">Latitude</label>
                <RadzenNumeric TValue="double" @bind-Value="latitude" Format="F6" Style="width:100%" />
            </div>
            <div class="mb-3">
                <label class="form-label">Longitude</label>
                <RadzenNumeric TValue="double" @bind-Value="longitude" Format="F6" Style="width:100%" />
            </div>
            <div class="mb-3">
                <label class="form-label">Resolution (0–15)</label>
                <RadzenNumeric TValue="int" @bind-Value="resolution" Min="0" Max="15" Style="width:100%" />
            </div>
            <div class="mb-3 d-flex align-items-center gap-2">
                <RadzenButton Text="Preview H3 Index" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Click="PreviewH3" />
                @if (previewH3 is not null) { <code>@previewH3</code> }
            </div>
        }
        else
        {
            <div class="mb-3">
                <label class="form-label">H3 Index</label>
                <RadzenTextBox @bind-Value="h3Index" Style="width:100%;font-family:monospace" />
            </div>
        }

        <RadzenButton Text="@(submitting ? "Saving…" : "Save")" Icon="save" ButtonStyle="ButtonStyle.Primary"
                      Disabled="@submitting" Click="Submit" />
        <RadzenButton Text="Cancel" ButtonStyle="ButtonStyle.Light" class="ms-2"
                      Click="@(() => NavigationManager.NavigateTo("/hexagons"))" />
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private enum InputMode { Coordinates, H3Index }

    private List<ImageOption> images = [];
    private int imageId;
    private InputMode mode = InputMode.H3Index;
    private double latitude;
    private double longitude;
    private int resolution = 15;
    private string? previewH3;
    private string? h3Index;
    private bool loaded;
    private bool submitting;

    protected override async Task OnInitializedAsync()
    {
        var client = HttpClientFactory.CreateClient("ExifApi");
        try
        {
            var hex = await client.GetFromJsonAsync<HexagonRow>($"api/hexagons/{Id}");
            if (hex is null) { NotificationService.Notify(NotificationSeverity.Error, "Not found", "Hexagon not found.", 5000); return; }
            imageId = hex.ImageId ?? 0;
            h3Index = hex.H3Index;
            resolution = hex.Resolution;
            latitude = hex.Lat;
            longitude = hex.Lon;
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Load failed", ex.Message, 5000);
            return;
        }

        try
        {
            images = await client.GetFromJsonAsync<List<ImageOption>>("api/images/") ?? [];
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Load failed", ex.Message, 5000);
            return;
        }

        loaded = true;
    }

    private async Task PreviewH3()
    {
        previewH3 = null;
        try
        {
            var client = HttpClientFactory.CreateClient("ExifApi");
            var lat = latitude.ToString(System.Globalization.CultureInfo.InvariantCulture);
            var lon = longitude.ToString(System.Globalization.CultureInfo.InvariantCulture);
            var result = await client.GetFromJsonAsync<H3Preview>($"api/h3/cell?lat={lat}&lon={lon}&resolution={resolution}");
            previewH3 = result?.H3Index;
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Preview failed", ex.Message, 5000);
        }
    }

    private async Task Submit()
    {
        if (imageId == 0) { NotificationService.Notify(NotificationSeverity.Warning, "Validation", "Please select an image.", 4000); return; }

        submitting = true;
        try
        {
            var client = HttpClientFactory.CreateClient("ExifApi");
            object payload = mode == InputMode.Coordinates
                ? new { ImageId = (int?)imageId, Latitude = (double?)latitude, Longitude = (double?)longitude, Resolution = (int?)resolution, H3Index = (string?)null }
                : new { ImageId = (int?)imageId, Latitude = (double?)null, Longitude = (double?)null, Resolution = (int?)null, H3Index = h3Index };

            var response = await client.PutAsJsonAsync($"api/hexagons/{Id}", payload);
            if (response.IsSuccessStatusCode)
            {
                NotificationService.Notify(NotificationSeverity.Success, "Saved", "Hexagon updated.", 3000);
                NavigationManager.NavigateTo("/hexagons");
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                NotificationService.Notify(NotificationSeverity.Error, "Save failed", $"({(int)response.StatusCode}) {body}", 6000);
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error", ex.Message, 6000);
        }
        finally
        {
            submitting = false;
        }
    }

    private record HexagonRow(int Id, string H3Index, int Resolution, double Lat, double Lon, int? ImageId);
    private record ImageOption(int Id, string FileName);
    private record H3Preview(string H3Index, int Resolution, double Lat, double Lon);
}
