@page "/turbulences/create"
@using ExifApi.Data.Entities
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService
@rendermode InteractiveServer

<PageTitle>New Turbulence</PageTitle>
<h1>New Turbulence</h1>

<div style="max-width:500px">
    <div class="mb-3">
        <label class="form-label fw-semibold">Index</label>
        <RadzenNumeric TValue="int" @bind-Value="index" Min="0" Max="10" Style="width:100%" />
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold">Road Turbulence Type</label>
        <RadzenDropDown @bind-Value="selectedTypes"
                        Data="@turbulenceTypeOptions"
                        Multiple="true"
                        AllowClear="true"
                        Placeholder="— select types —"
                        Style="width:100%" />
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold">Hexagon</label>
        <RadzenRadioButtonList @bind-Value="locationMode" TValue="string" class="mb-2">
            <Items>
                <RadzenRadioButtonListItem Text="Select Hexagon" Value="@("hexagon")" />
                <RadzenRadioButtonListItem Text="H3 Index" Value="@("h3index")" />
            </Items>
        </RadzenRadioButtonList>
        @if (locationMode == "hexagon")
        {
            <RadzenDropDown TValue="int?" @bind-Value="hexagonId" Data="@hexagons"
                            TextProperty="H3Index" ValueProperty="Id" AllowClear="true"
                            Placeholder="— none —" Style="width:100%" />
        }
        else
        {
            <RadzenTextBox @bind-Value="h3Index" Placeholder="e.g. 8f39100e1a500e2" Style="width:100%" />
        }
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold">Session (optional)</label>
        <RadzenDropDown TValue="int?" @bind-Value="sessionId" Data="@sessions"
                        TextProperty="Label" ValueProperty="Id" AllowClear="true"
                        Placeholder="— none —" Style="width:100%" />
    </div>

    <RadzenButton Text="@(submitting ? "Saving..." : "Create")" Icon="add" ButtonStyle="ButtonStyle.Primary"
                  Disabled="@submitting" Click="Submit" />
    <RadzenButton Text="Cancel" ButtonStyle="ButtonStyle.Light" class="ms-2"
                  Click="@(() => NavigationManager.NavigateTo("/turbulences"))" />
</div>

@code {
    private static readonly IEnumerable<RoadTurbulenceType> turbulenceTypeOptions =
    [
        RoadTurbulenceType.Pothole,
        RoadTurbulenceType.Speedbump,
        RoadTurbulenceType.LongitudinalCrack,
        RoadTurbulenceType.TransverseCrack,
        RoadTurbulenceType.Depression,
        RoadTurbulenceType.AbruptSwerving,
        RoadTurbulenceType.WaterLeakage,
    ];

    private int index;
    private IEnumerable<RoadTurbulenceType> selectedTypes = [];
    private string locationMode = "hexagon";
    private int? hexagonId;
    private string h3Index = "";
    private int? sessionId;
    private List<HexagonOption> hexagons = [];
    private List<SessionOption> sessions = [];
    private bool submitting;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("ExifApi");
            var hexagonsTask = client.GetFromJsonAsync<List<HexagonOption>>("api/hexagons/");
            var sessionsTask = client.GetFromJsonAsync<List<SessionOption>>("api/sessions/");
            await Task.WhenAll(hexagonsTask, sessionsTask);
            hexagons = hexagonsTask.Result ?? [];
            sessions = sessionsTask.Result ?? [];
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Load failed", ex.Message, 5000);
        }
    }

    private async Task Submit()
    {
        submitting = true;
        try
        {
            var turbulenceType = selectedTypes.Any()
                ? selectedTypes.Aggregate((a, b) => a | b)
                : RoadTurbulenceType.Pothole;

            var payload = locationMode == "h3index"
                ? (object)new { Index = index, Kind = turbulenceType, H3Index = h3Index, SessionId = sessionId }
                : new { Index = index, Kind = turbulenceType, HexagonId = hexagonId, SessionId = sessionId };

            var client = HttpClientFactory.CreateClient("ExifApi");
            var response = await client.PostAsJsonAsync("api/turbulences", payload);

            if (response.IsSuccessStatusCode)
            {
                NotificationService.Notify(NotificationSeverity.Success, "Created", "Turbulence record created.", 3000);
                NavigationManager.NavigateTo("/turbulences");
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                NotificationService.Notify(NotificationSeverity.Error, "Save failed", $"({(int)response.StatusCode}) {body}", 6000);
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error", ex.Message, 6000);
        }
        finally
        {
            submitting = false;
        }
    }

    private record HexagonOption(int Id, string H3Index, int Resolution);
    private record SessionOption(int Id, int AgentId)
    {
        public string Label => $"#{Id} — Agent #{AgentId}";
    }
}
