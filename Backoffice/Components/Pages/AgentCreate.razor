@page "/agents/create"
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService
@rendermode InteractiveServer

<PageTitle>New Agent</PageTitle>
<h1>New Agent</h1>

<div style="max-width:500px">

    <div class="mb-3">
        <label class="form-label fw-semibold">Name</label>
        <RadzenTextBox @bind-Value="name" Style="width:100%" />
    </div>

    <RadzenButton Text="@(submitting ? "Saving..." : "Create")" Icon="add" ButtonStyle="ButtonStyle.Primary"
                  Disabled="@(submitting || string.IsNullOrWhiteSpace(name))" Click="Submit" />
    <RadzenButton Text="Cancel" ButtonStyle="ButtonStyle.Light" class="ms-2"
                  Click="@(() => NavigationManager.NavigateTo("/agents"))" />
</div>

@code {
    private string name = string.Empty;
    private bool submitting;

    private async Task Submit()
    {
        submitting = true;
        try
        {
            var payload = new { Name = name };

            var client = HttpClientFactory.CreateClient("ExifApi");
            var response = await client.PostAsJsonAsync("api/agents", payload);

            if (response.IsSuccessStatusCode)
            {
                NotificationService.Notify(NotificationSeverity.Success, "Created", "Agent created.", 3000);
                NavigationManager.NavigateTo("/agents");
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                NotificationService.Notify(NotificationSeverity.Error, "Save failed", $"({(int)response.StatusCode}) {body}", 6000);
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error", ex.Message, 6000);
        }
        finally
        {
            submitting = false;
        }
    }
}
