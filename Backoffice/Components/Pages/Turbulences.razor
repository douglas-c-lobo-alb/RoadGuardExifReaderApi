@page "/turbulences"
@using ExifApi.Data.Entities
@inject IHttpClientFactory HttpClientFactory
@inject DialogService DialogService
@inject NotificationService NotificationService
@rendermode InteractiveServer

<PageTitle>Turbulences</PageTitle>

<h1>Road Turbulences</h1>

<div style="overflow-x:auto">
<RadzenDataGrid TItem="TurbulenceRow" Data="@turbulences" IsLoading="@(turbulences is null)"
                AllowPaging="true" PageSize="20"
                AllowSorting="true" AllowFiltering="true"
                FilterMode="FilterMode.SimpleWithMenu"
                PagerHorizontalAlign="HorizontalAlign.Left"
                ShowPagingSummary="true" Density="Density.Compact"
                Style="min-width:600px">
    <Columns>
        <RadzenDataGridColumn TItem="TurbulenceRow" Property="Id" Title="Id" Width="80px" />
        <RadzenDataGridColumn TItem="TurbulenceRow" Property="Index" Title="Index" Width="100px" />
        <RadzenDataGridColumn TItem="TurbulenceRow" Property="RoadTurbulenceType" Title="Type">
            <Template Context="t">
                @if (t.RoadTurbulenceType == RoadTurbulenceType.None) { <span class="text-muted">None</span> }
                else { @t.RoadTurbulenceType.ToString() }
            </Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn TItem="TurbulenceRow" Property="HexagonId" Title="Hexagon" Width="120px">
            <Template Context="t">@(t.HexagonId?.ToString() ?? "—")</Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn TItem="TurbulenceRow" Property="DateCreated" Title="Date Created"
                              Width="160px" FormatString="{0:yyyy-MM-dd HH:mm}" />
        <RadzenDataGridColumn TItem="TurbulenceRow" Title="" Width="80px" Sortable="false" Filterable="false" TextAlign="TextAlign.End">
            <Template Context="t">
                <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small"
                              Click="@(() => ConfirmDelete(t))" />
            </Template>
        </RadzenDataGridColumn>
    </Columns>
</RadzenDataGrid>
</div>

@code {
    private List<TurbulenceRow>? turbulences;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("ExifApi");
            turbulences = await client.GetFromJsonAsync<List<TurbulenceRow>>("api/turbulences/") ?? [];
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Load failed", ex.Message, 5000);
        }
    }

    private async Task ConfirmDelete(TurbulenceRow t)
    {
        var confirmed = await DialogService.Confirm(
            $"Delete turbulence record #{t.Id}? This cannot be undone.",
            "Confirm Delete",
            new ConfirmOptions { OkButtonText = "Delete", CancelButtonText = "Cancel" });
        if (confirmed == true)
            await Delete(t.Id);
    }

    private async Task Delete(int id)
    {
        var client = HttpClientFactory.CreateClient("ExifApi");
        var response = await client.DeleteAsync($"api/turbulences/{id}");
        if (response.IsSuccessStatusCode)
        {
            NotificationService.Notify(NotificationSeverity.Success, "Deleted", "Turbulence record removed.", 3000);
            await Load();
        }
        else
            NotificationService.Notify(NotificationSeverity.Error, "Delete failed", $"Status {(int)response.StatusCode}", 5000);
    }

    private record TurbulenceRow(int Id, int Index, RoadTurbulenceType RoadTurbulenceType, int? HexagonId, DateTime DateCreated);
}
