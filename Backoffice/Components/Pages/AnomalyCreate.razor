@page "/anomalies/create"
@using ExifApi.Data.Entities
@using System.Text.Json
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService
@rendermode InteractiveServer

<PageTitle>New Anomaly</PageTitle>
<h1>New Anomaly</h1>

<div style="max-width:600px">

    <div class="mb-3">
        <label class="form-label fw-semibold">Location</label>
        <RadzenRadioButtonList @bind-Value="locationMode" TValue="string" class="mb-2">
            <Items>
                <RadzenRadioButtonListItem Text="Hexagon" Value="@("hexagon")" />
                <RadzenRadioButtonListItem Text="H3 Index" Value="@("h3index")" />
                <RadzenRadioButtonListItem Text="Coordinates" Value="@("coords")" />
                <RadzenRadioButtonListItem Text="From Image" Value="@("image")" />
            </Items>
        </RadzenRadioButtonList>

        @if (locationMode == "hexagon")
        {
            <RadzenDropDown TValue="int"
                            @bind-Value="hexagonId"
                            Data="@hexagons"
                            TextProperty="H3Index"
                            ValueProperty="Id"
                            Placeholder="— select a hexagon —"
                            Style="width:100%" />
            @if (showValidation && hexagonId == 0)
            {
                <div class="text-danger small mt-1">Hexagon is required.</div>
            }
        }
        else if (locationMode == "h3index")
        {
            <RadzenTextBox @bind-Value="h3Index" Placeholder="e.g. 8f39100e1a500e2" Style="width:100%" />
            @if (showValidation && string.IsNullOrWhiteSpace(h3Index))
            {
                <div class="text-danger small mt-1">H3 Index is required.</div>
            }
        }
        else if (locationMode == "coords")
        {
            <div class="row g-2">
                <div class="col-6">
                    <label class="form-label small">Latitude</label>
                    <RadzenNumeric TValue="decimal" @bind-Value="latitude" Format="F6" Step="0.000001m" Style="width:100%" />
                </div>
                <div class="col-6">
                    <label class="form-label small">Longitude</label>
                    <RadzenNumeric TValue="decimal" @bind-Value="longitude" Format="F6" Step="0.000001m" Style="width:100%" />
                </div>
            </div>
        }
        else if (locationMode == "image")
        {
            <RadzenDropDown TValue="int"
                            @bind-Value="imageId"
                            Data="@images"
                            TextProperty="FileName"
                            ValueProperty="Id"
                            Placeholder="— select an image —"
                            Style="width:100%" />
            @if (showValidation && imageId == 0)
            {
                <div class="text-danger small mt-1">Image is required.</div>
            }
        }
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold">Anomaly Type</label>
        <RadzenDropDown @bind-Value="selectedAnomalyTypes"
                        Data="@anomalyTypeOptions"
                        Multiple="true"
                        AllowClear="true"
                        Placeholder="— select types —"
                        Style="width:100%" />
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold">Confidence (0–1)</label>
        <RadzenNumeric TValue="decimal" @bind-Value="confidence"
                       Format="F2" Min="0" Max="1" Step="0.01m"
                       Style="width:100%" />
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold">Notes (JSON)</label>
        <RadzenTextArea @bind-Value="notesJson" Rows="3"
                        Style="width:100%;font-family:monospace" />
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold">Bounding Box</label>
        <div class="row g-2 mt-1">
            <div class="col-6">
                <label class="form-label small">X1</label>
                <RadzenNumeric TValue="int" @bind-Value="boxX1" Min="0" Style="width:100%" />
            </div>
            <div class="col-6">
                <label class="form-label small">Y1</label>
                <RadzenNumeric TValue="int" @bind-Value="boxY1" Min="0" Style="width:100%" />
            </div>
            <div class="col-6">
                <label class="form-label small">X2</label>
                <RadzenNumeric TValue="int" @bind-Value="boxX2" Min="0" Style="width:100%" />
            </div>
            <div class="col-6">
                <label class="form-label small">Y2</label>
                <RadzenNumeric TValue="int" @bind-Value="boxY2" Min="0" Style="width:100%" />
            </div>
        </div>
    </div>

    <RadzenButton Text="@(submitting ? "Saving..." : "Create")" Icon="add" ButtonStyle="ButtonStyle.Primary"
                  Disabled="@submitting" Click="Submit" />
    <RadzenButton Text="Cancel" ButtonStyle="ButtonStyle.Light" class="ms-2"
                  Click="@(() => NavigationManager.NavigateTo("/anomalies"))" />

</div>

@code {
    private static readonly IEnumerable<AnomalyType> anomalyTypeOptions =
    [
        AnomalyType.Pothole,
        AnomalyType.RoadCrack,
        AnomalyType.MissingRoadSign,
        AnomalyType.WaterLeakage,
    ];

    private string locationMode = "image";
    private int hexagonId;
    private string h3Index = "";
    private decimal latitude;
    private decimal longitude;
    private int imageId;
    private IEnumerable<AnomalyType> selectedAnomalyTypes = [];
    private decimal confidence = 0.85m;
    private string? notesJson;
    private int boxX1, boxY1, boxX2, boxY2;
    private bool submitting;
    private bool showValidation;

    private List<HexagonOption> hexagons = [];
    private List<ImageOption> images = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("ExifApi");
            var hexTask = client.GetFromJsonAsync<List<HexagonOption>>("api/hexagons/");
            var imgTask = client.GetFromJsonAsync<List<ImageOption>>("api/images/");
            await Task.WhenAll(hexTask, imgTask);
            hexagons = hexTask.Result ?? [];
            images = imgTask.Result ?? [];
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Load failed", ex.Message, 5000);
        }
    }

    private async Task Submit()
    {
        showValidation = true;
        if (locationMode == "hexagon" && hexagonId == 0) return;
        if (locationMode == "h3index" && string.IsNullOrWhiteSpace(h3Index)) return;
        if (locationMode == "image" && imageId == 0) return;

        JsonDocument? notesDoc = null;
        if (!string.IsNullOrWhiteSpace(notesJson))
        {
            try { notesDoc = JsonDocument.Parse(notesJson); }
            catch (JsonException)
            {
                NotificationService.Notify(NotificationSeverity.Error, "Invalid JSON", "Notes field contains invalid JSON.", 5000);
                return;
            }
        }

        submitting = true;
        try
        {
            var anomalyType = selectedAnomalyTypes.Any()
                ? selectedAnomalyTypes.Aggregate((a, b) => a | b)
                : AnomalyType.Pothole;

            object payload = locationMode switch
            {
                "hexagon" => new { HexagonId = hexagonId, Kind = anomalyType, Confidence = confidence, Metadata = notesDoc, BoxX1 = boxX1, BoxY1 = boxY1, BoxX2 = boxX2, BoxY2 = boxY2 },
                "h3index" => new { H3Index = h3Index, Kind = anomalyType, Confidence = confidence, Metadata = notesDoc, BoxX1 = boxX1, BoxY1 = boxY1, BoxX2 = boxX2, BoxY2 = boxY2 },
                "coords"  => new { Latitude = latitude, Longitude = longitude, Kind = anomalyType, Confidence = confidence, Metadata = notesDoc, BoxX1 = boxX1, BoxY1 = boxY1, BoxX2 = boxX2, BoxY2 = boxY2 },
                _         => (object)new { ImageId = imageId, Kind = anomalyType, Confidence = confidence, Metadata = notesDoc, BoxX1 = boxX1, BoxY1 = boxY1, BoxX2 = boxX2, BoxY2 = boxY2 },
            };

            var client = HttpClientFactory.CreateClient("ExifApi");
            var response = await client.PostAsJsonAsync("api/anomalies", payload);

            if (response.IsSuccessStatusCode)
            {
                NotificationService.Notify(NotificationSeverity.Success, "Created", "Anomaly record created.", 3000);
                NavigationManager.NavigateTo("/anomalies");
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                NotificationService.Notify(NotificationSeverity.Error, "Save failed", $"({(int)response.StatusCode}) {body}", 6000);
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error", ex.Message, 6000);
        }
        finally
        {
            submitting = false;
        }
    }

    private record HexagonOption(int Id, string H3Index);
    private record ImageOption(int Id, string FileName);
}
