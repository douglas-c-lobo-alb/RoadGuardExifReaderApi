@page "/images"
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager NavigationManager
@inject IConfiguration Configuration
@rendermode InteractiveServer

<PageTitle>Images</PageTitle>

<h1>Images</h1>

<div class="mb-3">
    <a href="/images/upload" class="btn btn-primary">Upload Image</a>
    <button class="btn btn-secondary ms-2" @onclick="GenerateHexagons" disabled="@generating">
        @(generating ? "Generating..." : "Generate Hexagons")
    </button>
</div>

@if (errorMessage is not null)
{
    <div class="alert alert-danger">@errorMessage</div>
}
@if (successMessage is not null)
{
    <div class="alert alert-success">@successMessage</div>
}

@if (images is null)
{
    <p>Loading...</p>
}
else if (!images.Any())
{
    <p>No images registered yet.</p>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th style="width:60px"></th>
                <th>Id</th>
                <th>File</th>
                <th>Date Taken</th>
                <th>Camera</th>
                <th>Coordinates</th>
                <th>Hexagon</th>
                <th>Anomalies</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var img in images)
            {
                <tr>
                    <td style="padding:4px">
                        @if (!string.IsNullOrEmpty(img.FilePath))
                        {
                            <img src="@(apiBase + img.FilePath)"
                                 alt="@img.FileName"
                                 style="width:56px;height:40px;object-fit:cover;border-radius:3px;display:block" />
                        }
                    </td>
                    <td>@img.Id</td>
                    <td><span class="text-truncate d-block" style="max-width:160px" title="@img.FileName">@img.FileName</span></td>
                    <td>@img.DateTaken?.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@img.CameraMake @img.CameraModel</td>
                    <td class="small">
                        lat: <strong>@img.Latitude</strong> / lon: <strong>@img.Longitude</strong> / alt: <strong>@img.Altitude</strong>
                    </td>
                    <td>
                        @if (img.Hexagon is not null)
                        {
                            <a href="/hexagons/@img.Hexagon.Id/edit" class="text-decoration-none">
                                <span class="text-muted small">#@img.Hexagon.Id</span><br />
                                <code class="small">@img.Hexagon.H3Index</code>
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>
                    <td>
                        @if (img.AnomalyCount > 0)
                        {
                            <span class="badge bg-warning text-dark">@img.AnomalyCount</span>
                        }
                        else
                        {
                            <span class="text-muted small">0</span>
                        }
                    </td>
                    <td class="text-end">
                        <a href="/images/@img.Id/edit" class="btn btn-sm btn-outline-secondary me-1">Edit</a>
                        <button class="btn btn-sm btn-danger" @onclick="() => DeleteImage(img.Id)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<ImageRow>? images;
    private string? errorMessage;
    private string? successMessage;
    private bool generating;
    private string apiBase = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        apiBase = (Configuration["ApiBaseUrl"] ?? string.Empty).TrimEnd('/');
        await LoadImages();
    }

    private async Task LoadImages()
    {
        errorMessage = null;
        try
        {
            var client = HttpClientFactory.CreateClient("ExifApi");
            images = await client.GetFromJsonAsync<List<ImageRow>>("api/images/") ?? [];
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load images: {ex.Message}";
        }
    }

    private async Task DeleteImage(int id)
    {
        errorMessage = null;
        successMessage = null;
        var client = HttpClientFactory.CreateClient("ExifApi");
        var response = await client.DeleteAsync($"api/images/{id}");
        if (response.IsSuccessStatusCode)
            await LoadImages();
        else
            errorMessage = $"Delete failed ({response.StatusCode})";
    }

    private async Task GenerateHexagons()
    {
        generating = true;
        errorMessage = null;
        successMessage = null;
        try
        {
            var client = HttpClientFactory.CreateClient("ExifApi");
            var response = await client.PostAsync("api/h3/generate", null);
            if (response.IsSuccessStatusCode)
            {
                successMessage = "Hexagons generated successfully";
                await LoadImages();
            }
            else
                errorMessage = $"Generation failed ({response.StatusCode})";
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            generating = false;
        }
    }

    private record HexagonRow(int Id, string H3Index, int Resolution);
    private record ImageRow(int Id, string FileName, string FilePath,
        string? CameraMake, string? CameraModel, DateTime? DateTaken,
        decimal? Latitude, decimal? Longitude, double? Altitude,
        int AnomalyCount, HexagonRow? Hexagon);
}
