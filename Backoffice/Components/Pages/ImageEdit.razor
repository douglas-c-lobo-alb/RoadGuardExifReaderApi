@page "/images/{Id:int}/edit"
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager NavigationManager
@inject IConfiguration Configuration
@rendermode InteractiveServer

<PageTitle>Edit Image</PageTitle>

<h1>Edit Image</h1>

@if (loadError is not null)
{
    <div class="alert alert-danger">@loadError</div>
}
else if (!loaded)
{
    <p>Loading...</p>
}
else
{
    @if (errorMessage is not null)
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    <div class="row mb-4">
        <div class="col-auto">
            @if (!string.IsNullOrEmpty(filePath))
            {
                <img src="@(apiBase + filePath)" alt="@fileName"
                     style="width:120px;height:90px;object-fit:cover;border-radius:4px;display:block" />
            }
        </div>
        <div class="col">
            <div class="fw-semibold">@fileName</div>
            <div class="text-muted small">
                Image #@Id
                @if (hexagonId > 0)
                {
                    <span> &mdash; Hexagon <a href="/hexagons/@hexagonId/edit">#@hexagonId</a>
                        @if (!string.IsNullOrEmpty(h3Index))
                        {
                            <text> (<code>@h3Index</code>)</text>
                        }
                    </span>
                }
            </div>
        </div>
    </div>

    <div style="max-width: 500px;">
        <div class="mb-3">
            <label class="form-label">Camera Make</label>
            <input class="form-control" type="text" @bind="cameraMake" />
        </div>
        <div class="mb-3">
            <label class="form-label">Camera Model</label>
            <input class="form-control" type="text" @bind="cameraModel" />
        </div>
        <div class="mb-3">
            <label class="form-label">Date Taken</label>
            <input class="form-control" type="datetime-local" @bind="dateTaken" />
        </div>
        <div class="row g-3 mb-3">
            <div class="col">
                <label class="form-label">Latitude</label>
                <input class="form-control" type="number" step="any" @bind="latitude" />
            </div>
            <div class="col">
                <label class="form-label">Longitude</label>
                <input class="form-control" type="number" step="any" @bind="longitude" />
            </div>
        </div>
        <div class="row g-3 mb-3">
            <div class="col">
                <label class="form-label">Altitude</label>
                <input class="form-control" type="number" step="any" @bind="altitude" />
            </div>
            <div class="col">
                <label class="form-label">Heading</label>
                <input class="form-control" type="number" step="any" @bind="heading" />
            </div>
        </div>
        <div class="mb-3">
            <label class="form-label">Anomaly Notes</label>
            <textarea class="form-control" rows="3" @bind="anomalyNotes"></textarea>
        </div>

        <button class="btn btn-primary" @onclick="Submit" disabled="@submitting">
            @(submitting ? "Saving…" : "Save")
        </button>
        <a href="/images" class="btn btn-secondary ms-2">Cancel</a>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private string apiBase = string.Empty;
    private string? fileName;
    private string? filePath;
    private int hexagonId;
    private string? h3Index;

    private string? cameraMake;
    private string? cameraModel;
    private DateTime? dateTaken;
    private decimal? latitude;
    private decimal? longitude;
    private double? altitude;
    private decimal? heading;
    private string? anomalyNotes;

    private bool loaded;
    private bool submitting;
    private string? loadError;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        apiBase = (Configuration["ApiBaseUrl"] ?? string.Empty).TrimEnd('/');
        var client = HttpClientFactory.CreateClient("ExifApi");
        try
        {
            var img = await client.GetFromJsonAsync<ImageRow>($"api/images/{Id}");
            if (img is null) { loadError = "Image not found."; return; }

            fileName = img.FileName;
            filePath = img.FilePath;
            hexagonId = img.Hexagon?.Id ?? 0;
            h3Index = img.Hexagon?.H3Index;
            cameraMake = img.CameraMake;
            cameraModel = img.CameraModel;
            dateTaken = img.DateTaken;
            latitude = img.Latitude;
            longitude = img.Longitude;
            altitude = img.Altitude;
            heading = img.Heading;
            anomalyNotes = img.AnomalyNotes;
        }
        catch (Exception ex)
        {
            loadError = $"Failed to load image: {ex.Message}";
            return;
        }
        loaded = true;
    }

    private async Task Submit()
    {
        errorMessage = null;
        submitting = true;
        try
        {
            var client = HttpClientFactory.CreateClient("ExifApi");
            var payload = new
            {
                CameraMake = cameraMake,
                CameraModel = cameraModel,
                DateTaken = dateTaken,
                Latitude = latitude,
                Longitude = longitude,
                Altitude = altitude,
                Heading = heading,
                AnomalyNotes = anomalyNotes
            };
            var response = await client.PutAsJsonAsync($"api/images/{Id}", payload);
            if (response.IsSuccessStatusCode)
                NavigationManager.NavigateTo("/images");
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                errorMessage = $"Failed ({(int)response.StatusCode}): {body}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            submitting = false;
        }
    }

    private record HexagonRow(int Id, string H3Index, int Resolution);
    private record ImageRow(int Id, string FileName, string FilePath,
        string? CameraMake, string? CameraModel, DateTime? DateTaken,
        decimal? Latitude, decimal? Longitude, double? Altitude, decimal? Heading,
        string? AnomalyNotes, HexagonRow? Hexagon);
}
