@page "/sessions"
@using ExifApi.Data.Entities
@inject IHttpClientFactory HttpClientFactory
@inject DialogService DialogService
@inject NotificationService NotificationService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Sessions</PageTitle>

<h1>Sessions</h1>

<div class="mb-3">
    <RadzenButton Text="New Session" Icon="add" ButtonStyle="ButtonStyle.Primary"
                  Click="@(() => NavigationManager.NavigateTo("/sessions/create"))" />
</div>

<div style="overflow-x:auto">
    <RadzenDataGrid TItem="SessionRow" Data="@sessions" IsLoading="@(sessions is null)" AllowPaging="true" PageSize="20"
                    AllowSorting="true" AllowFiltering="true" FilterMode="FilterMode.SimpleWithMenu"
                    PagerHorizontalAlign="HorizontalAlign.Left" ShowPagingSummary="true" Density="Density.Compact"
                    Style="min-width:600px">
        <Columns>
            <RadzenDataGridColumn TItem="SessionRow" Property="Id" Title="Id" Width="80px" />
            <RadzenDataGridColumn TItem="SessionRow" Property="AgentId" Title="Agent" Width="90px" />
            <RadzenDataGridColumn TItem="SessionRow" Property="StartedAt" Title="Started At" Width="160px"
                                  FormatString="{0:yyyy-MM-dd HH:mm}" />
            <RadzenDataGridColumn TItem="SessionRow" Property="FinishedAt" Title="Finished At" Width="160px">
                <Template Context="s">
                    @if (s.FinishedAt is null)
                    {
                        <RadzenBadge Text="Active" BadgeStyle="BadgeStyle.Success" />
                    }
                    else
                    {
                        @s.FinishedAt.Value.ToString("yyyy-MM-dd HH:mm")
                    }
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="SessionRow" Title="" Width="110px" Sortable="false" Filterable="false"
                                  TextAlign="TextAlign.End">
                <Template Context="s">
                    @if (s.FinishedAt is null)
                    {
                        <RadzenButton Icon="check_circle" ButtonStyle="ButtonStyle.Success" Size="ButtonSize.Small" class="me-1"
                                      Click="@(() => Finish(s))" />
                    }
                    <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small"
                                  Click="@(() => ConfirmDelete(s))" />
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
</div>

@code {
    private List<SessionRow>? sessions;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("ExifApi");
            sessions = await client.GetFromJsonAsync<List<SessionRow>>("api/sessions/") ?? [];
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Load failed", ex.Message, 5000);
        }
    }

    private async Task Finish(SessionRow s)
    {
        var client = HttpClientFactory.CreateClient("ExifApi");
        var response = await client.PostAsync($"api/sessions/{s.Id}/finish", null);
        if (response.IsSuccessStatusCode)
        {
            NotificationService.Notify(NotificationSeverity.Success, "Finished", "Session finished.", 3000);
            await Load();
        }
        else
            NotificationService.Notify(NotificationSeverity.Error, "Finish failed", $"Status {(int)response.StatusCode}", 5000);
    }

    private async Task ConfirmDelete(SessionRow s)
    {
        var confirmed = await DialogService.Confirm(
            $"Delete session #{s.Id}? This cannot be undone.",
            "Confirm Delete",
            new ConfirmOptions { OkButtonText = "Delete", CancelButtonText = "Cancel" });
        if (confirmed == true)
            await Delete(s.Id);
    }

    private async Task Delete(int id)
    {
        var client = HttpClientFactory.CreateClient("ExifApi");
        var response = await client.DeleteAsync($"api/sessions/{id}");
        if (response.IsSuccessStatusCode)
        {
            NotificationService.Notify(NotificationSeverity.Success, "Deleted", "Session removed.", 3000);
            await Load();
        }
        else
            NotificationService.Notify(NotificationSeverity.Error, "Delete failed", $"Status {(int)response.StatusCode}", 5000);
    }

    private record SessionRow(int Id, string AgentId, DateTime StartedAt, DateTime? FinishedAt);
}
