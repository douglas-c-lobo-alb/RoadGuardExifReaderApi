{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=Data/exifapi.db"
  },
  "H3": {
    "DefaultResolution": 13,
    "AnomalyResolution": 13
  },
  "Votes": {
    "Thresholds": {
      "Default": 4,
      "Pothole": 3,
      "AnimalCorpse": 2,
      "WaterLeakage": 6
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Image": {
    "Path": "images"
  },
  "Redis": {
    "Configuration": "redis://server.futurelabsinnovations.lan:6379",
    "MultiplexerConfiguration": "server.futurelabsinnovations.lan:6379",
    "TtlMinutes": 5
  },
  "AllowedHosts": "*",
  "Release": {
    "Version": "0.9.4"
  }
}
